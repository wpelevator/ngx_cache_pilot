if [ "$HTTP_PROXY" = "YES" ]; then
    have=NGX_HTTP_PROXY . auto/have
fi

if [ "$HTTP_FASTCGI" = "YES" ]; then
    have=NGX_HTTP_FASTCGI . auto/have
fi

if [ "$HTTP_SCGI" = "YES" ]; then
    have=NGX_HTTP_SCGI . auto/have
fi

if [ "$HTTP_UWSGI" = "YES" ]; then
    have=NGX_HTTP_UWSGI . auto/have
fi

if [ "$USE_THREADS" = "YES" ]; then
    have=NGX_CACHE_PILOT_THREADS . auto/have
fi

ngx_addon_name=ngx_http_cache_pilot_module

CACHE_PILOT_SRCS="$ngx_addon_dir/src/ngx_cache_pilot_module.c \
$ngx_addon_dir/src/ngx_cache_pilot_index.c \
$ngx_addon_dir/src/ngx_cache_pilot_index_store.c \
$ngx_addon_dir/src/ngx_cache_pilot_index_watch_linux.c \
$ngx_addon_dir/src/ngx_cache_pilot_metrics.c"

CACHE_PURGE_DEPS="$ngx_addon_dir/src/ngx_cache_pilot_index.h \
$ngx_addon_dir/src/ngx_cache_pilot_index_store_internal.h \
$ngx_addon_dir/src/ngx_cache_pilot_metrics.h"

NGX_CACHE_PILOT_MODULE_LIBS=

if [ -n "$ngx_module_link" ]; then
    ngx_module_type=HTTP
    ngx_module_name="$ngx_addon_name"
    ngx_module_srcs="$CACHE_PILOT_SRCS"
    ngx_module_deps="$CACHE_PURGE_DEPS"
    ngx_module_libs="$NGX_CACHE_PILOT_MODULE_LIBS"

    . auto/module
else
    HTTP_MODULES="$HTTP_MODULES $ngx_addon_name"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS $CACHE_PILOT_SRCS"
    NGX_ADDON_LIBS="$NGX_ADDON_LIBS $NGX_CACHE_PILOT_MODULE_LIBS"
fi

have=NGX_CACHE_PILOT_MODULE . auto/have
