if [ "$HTTP_PROXY" = "YES" ]; then
    have=NGX_HTTP_PROXY . auto/have
fi

if [ "$HTTP_FASTCGI" = "YES" ]; then
    have=NGX_HTTP_FASTCGI . auto/have
fi

if [ "$HTTP_SCGI" = "YES" ]; then
    have=NGX_HTTP_SCGI . auto/have
fi

if [ "$HTTP_UWSGI" = "YES" ]; then
    have=NGX_HTTP_UWSGI . auto/have
fi

if [ "$USE_THREADS" = "YES" ]; then
    have=NGX_CACHE_PURGE_THREADS . auto/have
fi

ngx_addon_name=ngx_http_cache_purge_module

CACHE_PURGE_SRCS="$ngx_addon_dir/src/ngx_cache_purge_module.c \
$ngx_addon_dir/src/ngx_cache_purge_tag.c \
$ngx_addon_dir/src/ngx_cache_purge_tag_store.c \
$ngx_addon_dir/src/ngx_cache_purge_tag_store_redis.c \
$ngx_addon_dir/src/ngx_cache_purge_tag_watch_linux.c \
$ngx_addon_dir/src/ngx_cache_purge_metrics.c"

CACHE_PURGE_DEPS="$ngx_addon_dir/src/ngx_cache_purge_tag.h \
$ngx_addon_dir/src/ngx_cache_purge_tag_store_internal.h \
$ngx_addon_dir/src/ngx_cache_purge_metrics.h"

# Probe for SQLite3 — needed for the 'cache_pilot_tag_index sqlite' backend.
# If not found the module still builds but only the Redis backend is available.
ngx_feature="SQLite3 library"
ngx_feature_name="NGX_CACHE_PURGE_SQLITE"
ngx_feature_run=no
ngx_feature_incs="#include <sqlite3.h>"
ngx_feature_path=
ngx_feature_libs="-lsqlite3"
ngx_feature_test='sqlite3 *db; (void)sqlite3_open(":memory:", &db); sqlite3_close(db);'
. auto/feature

NGX_CACHE_PURGE_MODULE_LIBS=
if [ $ngx_found = yes ]; then
    CACHE_PURGE_SRCS="$CACHE_PURGE_SRCS \
$ngx_addon_dir/src/ngx_cache_purge_tag_store_sqlite.c"
    NGX_CACHE_PURGE_MODULE_LIBS="-lsqlite3"
fi

if [ -n "$ngx_module_link" ]; then
    ngx_module_type=HTTP
    ngx_module_name="$ngx_addon_name"
    ngx_module_srcs="$CACHE_PURGE_SRCS"
    ngx_module_deps="$CACHE_PURGE_DEPS"
    ngx_module_libs="$NGX_CACHE_PURGE_MODULE_LIBS"

    . auto/module
else
    HTTP_MODULES="$HTTP_MODULES $ngx_addon_name"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS $CACHE_PURGE_SRCS"
    NGX_ADDON_LIBS="$NGX_ADDON_LIBS $NGX_CACHE_PURGE_MODULE_LIBS"
fi

have=NGX_CACHE_PURGE_MODULE . auto/have
